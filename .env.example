# Database Configuration
# PostgreSQL is recommended for robust user authentication (login/signup) and article management.
# Update the credentials below with your actual PostgreSQL setup.
DATABASE_URL=postgresql://user:password@localhost:5432/similar_stories

# Application Settings
SECRET_KEY=your-super-secret-key-here
ENVIRONMENT=development
API_PORT=8000

# Additional settings (e.g., specific to articles if they are isolated)
# Only if necessary; typically, everything can run on the single DATABASE_URL
# ARTICLES_DB_URL=postgresql://user:password@localhost:5432/articles_db
